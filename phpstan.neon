parameters:
  level: 9
  paths:
    - src
    - tests
  excludePaths:
    analyse:
      - src/Container/LeagueContainer.php
      - src/Middleware/Handlers
      - src/Middleware/Interop.php
      - src/Routing/PhrouteResolver.php
      - tests/Fixture/Middlewares/InteropMiddleware.php
      - tests/Middleware/Multiple/Interop05.php
      - tests/Sample/Handlers/Interop.php
  ignoreErrors:
    - '#^Parameter \#1 \$cookies of method Rougin\\Slytherin\\Sample\\Builder\:\:setCookies\(\) expects array\<string, string\>, array\<mixed\> given\.$#'
    - '#^Parameter \#1 \$files of method Rougin\\Slytherin\\Sample\\Builder\:\:setFiles\(\) expects array\<string, array\<string, array\<mixed\>\>\>, array\<mixed\> given\.$#'
    - '#^Parameter \#1 \$query of method Rougin\\Slytherin\\Sample\\Builder\:\:setQuery\(\) expects array\<string, string\>, array\<mixed\> given\.$#'
    - '#^Parameter \#1 \$parsed of method Rougin\\Slytherin\\Sample\\Builder\:\:setParsed\(\) expects array\<string, string\>, array\<mixed\> given\.$#'
    - '#^Parameter \#1 \$server of method Rougin\\Slytherin\\Sample\\Builder\:\:setServer\(\) expects array\<string, string\>, array\<mixed\> given\.$#'
    - '#^Parameter \#1 \$server of class Rougin\\Slytherin\\Http\\ServerRequest constructor expects array\<string, string\>, array\<mixed\> given\.$#'
    - '#^Property Rougin\\Slytherin\\Template\\Twig\\RendererTest\:\:\$twig has unknown class Twig\\Environment as its type\.$#'
    - '#^PHPDoc tag @var contains unknown class Twig\\Loader\\FilesystemLoader\.$#'
    - '#^Property Rougin\\Slytherin\\Container\\AurynContainer\:\:\$injector has unknown class Auryn\\Injector as its type\.$#'
    - '#^Parameter \$injector of method Rougin\\Slytherin\\Container\\AurynContainer\:\:__construct\(\) has invalid type Auryn\\Injector\.$#'
    - '#^Call to method make\(\) on an unknown class Auryn\\Injector\.$#'
    - '#^Access to constant I_BINDINGS on an unknown class Auryn\\Injector\.$#'
    - '#^Access to constant I_DELEGATES on an unknown class Auryn\\Injector\.$#'
    - '#^Access to constant I_ALIASES on an unknown class Auryn\\Injector\.$#'
    - '#^Access to constant I_PREPARES on an unknown class Auryn\\Injector\.$#'
    - '#^Access to constant I_SHARES on an unknown class Auryn\\Injector\.$#'
    - '#^Call to method inspect\(\) on an unknown class Auryn\\Injector\.$#'
    - '#^Instantiated class Whoops\\Run not found\.$#'
    - '#^Property Rougin\\Slytherin\\Debug\\WhoopsErrorHandler\:\:\$whoops has unknown class Whoops\\Run as its type\.$#'
    - '#^Parameter \$whoops of method Rougin\\Slytherin\\Debug\\WhoopsErrorHandler\:\:__construct\(\) has invalid type Whoops\\Run\.$#'
    - '#^Method Rougin\\Slytherin\\Debug\\WhoopsErrorHandler\:\:getHandlers\(\) has invalid return type Whoops\\Handler\\HandlerInterface\.$#'
